{
  "namespaces": {
    "sqlite": {
      "paths": ["/workspace"],
      "git": {
        "denied_subcommands": [
          "push",
          "rebase",
          "reset",
          "clean",
          "gc",
          "checkout",
          "stash",
          "restore",
          "stash"
        ],
        "denied_patterns": ["--force(?:-with-lease)?", "-f\\b"]
      },
      "gh": {
        "denied_subcommands": ["repo", "release", "secret", "auth"]
      },
      "chmod": {
        "denied_patterns": [".*"]
      },
      "sed": {
        "allowed_patterns": ["-i"]
      }
    }
  }
}
